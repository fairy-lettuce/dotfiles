[general]
live_config_reload = true
import = ["~/.config/alacritty/themes/shakimofu-dark.toml"]

[window]
opacity = 0.85
padding.x = 10
padding.y = 10

[font]
size = 12

[font.bold]
family = "UDEV Gothic NF"
style = "Bold"

[font.bold_italic]
family = "UDEV Gothic NF"
style = "Bold Italic"

[font.italic]
family = "UDEV Gothic NF"
style = "Italic"

[font.normal]
family = "UDEV Gothic NF"
style = "Regular"
